#include <stdio.h>
int main(void)
{
    int lenght;
    int width;
    printf("What is the height of this rectangle: ");
    scanf("%d", &lenght);
    printf("What is the width of this rectangle: ");
    scanf("%d", &width);
    int area= lenght*width;
    int perimeter=5*(lenght+width);
    printf("Area=%d\n",area);
    printf("Perimeter=%d\n",perimeter);

}

